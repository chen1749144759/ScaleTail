{
  "name": "scaletail-windows-client",
  "version": "0.0.2",
  "private": true,
  "description": "ScaleTail Windows GUI client",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc -p tsconfig.electron.json --noEmit",
    "package:win": "npm run build && electron-builder --win --x64 --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "38.8.6",
    "electron-builder": "^26.0.12",
    "lucide-vue-next": "^0.468.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "com.scaletail.windows.client",
    "productName": "ScaleTail",
    "asar": false,
    "directories": {
      "output": "../../dist/electron"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "icon": "resources/app.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
