{
  "id": "common",
  "displayName": "ScaleTail Common",
  "repoName": "ScaleTail-Core",
  "description": "跨平台核心代码：daemon/CLI 主体、协议、网络、LocalAPI、共享工具、根 Go module 和通用构建文件。",
  "dependsOn": [],
  "include": [
    "**/*"
  ],
  "exclude": [
    ".git/**",
    ".idea/**",
    ".bencher/**",
    "dist/**",
    "client/electron/**",
    "installer/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/*_windows.go",
    "**/*_windows_test.go",
    "**/*_linux.go",
    "**/*_linux_test.go",
    "**/*_darwin.go",
    "**/*_darwin_test.go",
    "**/*_macos.go",
    "**/*_macos_test.go",
    "**/*_apple.go",
    "**/*_apple_test.go",
    "**/*_unix.go",
    "**/*_unix_test.go",
    "**/*_notwindows.go",
    "**/*_notwindows_test.go",
    "**/*_notlinux.go",
    "**/*_notlinux_test.go",
    "**/*_notmacos.go",
    "**/*_notmacos_test.go",
    "cmd/scaletail/*windows*",
    "cmd/scaletaild/*windows*",
    "docs/windows/**",
    "docs/sysv/**",
    "docs/bird/**",
    "licenses/windows.md",
    "licenses/apple.md",
    "packages/deb/**",
    "release/deb/**",
    "release/rpm/**",
    "scripts/build-windows-installer.ps1",
    "scripts/ensure-wintun.ps1",
    "scripts/build-linux-packages-wsl.ps1",
    "scripts/scaletail-linux-build.sh",
    "scripts/scaletail-linux-bootstrap.sh",
    "scripts/build-macos-pkg.sh",
    "tstest/tailmac/**"
  ],
  "verify": [
    "go list -mod=mod ./...",
    "go test ./cmd/scaletail/... ./cmd/scaletaild/... ./client/local ./ipn/localapi ./paths"
  ]
}
